func run() {
	S = __N__
	seed = 12345
	arr = []
	for i = 0; i < S; i++ {
		seed = (seed * 48271) % 2147483647
		arr += seed % 10000
	}
	for i = 1; i < S; i++ {
		key = arr[i]
		j = i - 1
		for k = 0; k < i; k++ {
			if j >= 0 && arr[j] > key {
				arr[j+1] = arr[j]
				j--
			} else {
				break
			}
		}
		arr[j+1] = key
	}
	sum = 0
	for i = 0; i < S; i++ {
		sum = (sum*31 + arr[i]) % 1000000007
	}
	return sum
}
run()
