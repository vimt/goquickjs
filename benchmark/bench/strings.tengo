text := import("text")
main := func() {
    N := __N__
    parts := []
    for i := 0; i < N; i++ {
        parts = append(parts, "item" + string(i % 1000))
    }
    s := text.join(parts, ",")
    sum := 0
    for i := 0; i < len(s); i++ {
        sum = (sum*31 + int(s[i])) % 1000000007
    }
    return sum
}
result := string(main())
