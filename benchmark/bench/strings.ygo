x := func() int {
	N := __N__
	itoa := func(v int) string {
		if v == 0 {
			return "0"
		}
		s := ""
		for v > 0 {
			s = string(rune('0'+v%10)) + s
			v = v / 10
		}
		return s
	}
	s := ""
	for i := 0; i < N; i++ {
		if i > 0 {
			s = s + ","
		}
		s = s + "item" + itoa(i%1000)
	}
	sum := 0
	for i := 0; i < len(s); i++ {
		sum = (sum*31 + int(s[i])) % 1000000007
	}
	return sum
}()
x
